# App Configuration
DEBUG=true
LOG_LEVEL=INFO

# Enable posting (set to true to actually post back)
ENABLE_JIRA_POSTING=false
ENABLE_SLACK_POSTING=false

# Agent
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Deep Research (Gemini - optional)
GOOGLE_API_KEY=your_google_api_key_here  # For deep web research tasks

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_SIGNING_SECRET=your-slack-signing-secret  # For webhook signature verification (optional)

# Jira Integration
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=ATATT3xFfGF0...

# Confluence Integration (for reading playbooks/wiki)
CONFLUENCE_EMAIL=your.email@company.com
CONFLUENCE_API_TOKEN=ATATT3xFfGF0...  # Scoped token with read:confluence-content.all
CONFLUENCE_CLOUD_ID=your-cloud-id  # Get from https://yoursite.atlassian.net/_edge/tenant_info
CONFLUENCE_WIKI_BASE_URL=https://yourcompany.atlassian.net/wiki  # For display URLs
CONFLUENCE_API_BASE_URL=https://api.atlassian.com/ex/confluence  # Scoped tokens use this

# Sentry
SENTRY_TOKEN=your-sentry-token
SENTRY_ORG=your-sentry-org

# GitHub (uses gh CLI - must be authenticated: gh auth login)
GITHUB_ORG=taptapsend

# Datadog
DD_API_KEY=your-datadog-api-key  # or DATADOG_API_KEY
DD_APP_KEY=your-datadog-app-key  # or DATADOG_APP_KEY
DD_SITE=datadoghq.com

# Brave Search (for web research)
BRAVE_SEARCH_API_KEY=your-brave-api-key  # Get from https://brave.com/search/api/
