# App Configuration
DEBUG=true
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000

# Enable posting (set to true to actually post back)
ENABLE_JIRA_POSTING=false
ENABLE_SLACK_POSTING=false

# Agent
AGENT_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_REASONING_MODEL=

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_VERIFY_SIGNATURE=true

# Jira Integration
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=ATATT3xFfGF0...
JIRA_WEBHOOK_SECRET=your-jira-webhook-secret
ENABLE_JIRA_WEBHOOK_VERIFICATION=true

# Confluence Integration (for reading playbooks/wiki)
CONFLUENCE_EMAIL=your.email@company.com
CONFLUENCE_API_TOKEN=ATATT3xFfGF0...  # Scoped token with read:confluence-content.all
CONFLUENCE_CLOUD_ID=your-cloud-id  # Get from https://yoursite.atlassian.net/_edge/tenant_info
CONFLUENCE_WIKI_BASE_URL=https://yourcompany.atlassian.net/wiki  # For display URLs
CONFLUENCE_API_BASE_URL=https://api.atlassian.com/ex/confluence  # Scoped tokens use this

# Sentry
SENTRY_TOKEN=your-sentry-token
SENTRY_ORG=your-sentry-org

# GitHub (uses gh CLI - must be authenticated: gh auth login)
GITHUB_ORG=your-github-org

# Datadog
DD_API_KEY=your-datadog-api-key  # or DATADOG_API_KEY
DD_APP_KEY=your-datadog-app-key  # or DATADOG_APP_KEY
DD_SITE=datadoghq.com

# Brave Search (for web research)
BRAVE_SEARCH_API_KEY=your-brave-api-key  # Get from https://brave.com/search/api/

# Queue
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_NAME=onkaul
JOB_TIMEOUT_SECONDS=900

# Repo configuration
REPO_CONFIG_PATH=./repository_config/repo_config_example.json
MONITORING_CONFIG_PATH=./repository_config/monitoring_config_example.json

# Local workspace for auto-cloned repos
WORKSPACE_DIR=./workplace

# Fix execution workspace (ephemeral)
FIX_WORKSPACE_DIR=./fixes

# Codex CLI (headless) for fix planning/apply
CODEX_PLAN_CMD=/Applications/Codex.app/Contents/Resources/codex exec --dangerously-bypass-approvals-and-sandbox --color never
CODEX_APPLY_CMD=/Applications/Codex.app/Contents/Resources/codex exec --dangerously-bypass-approvals-and-sandbox --color never
CODEX_TIMEOUT_SECONDS=1200

# Fix executor engine (codex or claude)
FIX_EXECUTOR_ENGINE=codex

# Claude CLI (headless) for fix planning/apply
CLAUDE_PLAN_CMD=claude -p --allowedTools "Bash,Read" --permission-mode acceptEdits --output-format text
CLAUDE_APPLY_CMD=claude -p --allowedTools "Bash,Read,Edit" --permission-mode acceptEdits --output-format text
CLAUDE_TIMEOUT_SECONDS=1200
